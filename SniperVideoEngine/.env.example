# =============================================================================
# DEZAFIRA — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha as chaves.

# ─── IA / LLM ──────────────────────────────────────────────────────────
# Obrigatório pelo menos uma. NVIDIA é a primária, DeepSeek é fallback.

# API Key da NVIDIA NIM (Llama 3.3 70B) — Primária
# Obter em: https://build.nvidia.com/
NVIDIA_API_KEY=

# API Key do DeepSeek — Fallback
# Obter em: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ─── MÍDIA ─────────────────────────────────────────────────────────────
# Obrigatório para buscar vídeos stock.

# API Key do Pexels (gratuito)
# Obter em: https://www.pexels.com/api/
PEXELS_API_KEY=

# ─── UPLOAD NO YOUTUBE ─────────────────────────────────────────────────
# Opcional — usado apenas para upload via API oficial (OAuth).

# OAuth 2.0 Client ID (Google Cloud Console)
GOOGLE_CLIENT_ID=
# OAuth 2.0 Client Secret
GOOGLE_CLIENT_SECRET=

# ─── TELEGRAM ──────────────────────────────────────────────────────────
# Opcional — notificações e controle remoto via Telegram.

# Token do Bot (criar em: https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=
# Seu Chat ID (para receber notificações)
TELEGRAM_CHAT_ID=

# ─── BANCO DE DADOS ───────────────────────────────────────────────────
# Opcional — padrão: SQLite local (dezafira.db)
# Para PostgreSQL (Railway):
# DATABASE_URL=postgresql://user:pass@host:5432/db
DATABASE_URL=

# ─── OPEN MONTAGE ─────────────────────────────────────────────────────
# Opcional — configurações do motor de renderização.

# Provider padrão para o OpenMontage ('nvidia' ou 'deepseek')
OPEN_MONTAGE_PROVIDER=nvidia
